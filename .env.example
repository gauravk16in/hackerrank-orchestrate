# Copy this file to `.env` and fill in your key. NEVER commit the real .env.
# Provider: gemini (primary) | bedrock | openai | anthropic
PROVIDER=gemini

# Gemini (primary). Either GEMINI_API_KEY or GOOGLE_API_KEY works.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: 0 disables Gemini "thinking" (cheaper/faster); raise for harder cases.
# GEMINI_THINKING_BUDGET=0

# --- Amazon Bedrock (Claude vision) — set PROVIDER=bedrock above ---
# Auth uses the standard AWS credential chain (AWS_ACCESS_KEY_ID/SECRET, profile, or role).
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- other providers (stubbed; swap PROVIDER above to use once implemented) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
